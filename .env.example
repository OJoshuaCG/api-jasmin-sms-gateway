# ======= Application variables ======= #
APP_ENV=development
# production: activa validaciones estrictas de claves, rechaza arranque si faltan
APP_NAME="Jasmin API Gateway"
# Genera con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=


# ======= Logger variables ======= #
LOGGER_LEVEL=INFO
LOGGER_MIDDLEWARE_ENABLED=True
LOGGER_MIDDLEWARE_SHOW_HEADERS=False
LOGGER_MIDDLEWARE_SHOW_QUERY_PARAMS=True
LOGGER_MIDDLEWARE_SHOW_BODY=True
LOGGER_MIDDLEWARE_SHOW_PATH_PARAMS=True
LOGGER_EXCEPTIONS_ENABLED=False
# Si True, suprime logs de solicitudes normales (2xx/3xx).
# Ante cualquier error (4xx/5xx) siempre registra: REQUEST → ERROR → RESPONSE.
LOGGER_MIDDLEWARE_ERRORS_ONLY=False

# ======= Docs variables ======= #
DOCS_ENABLED=True
# Si True, /docs /redoc y /openapi.json requieren usuario y contraseña (HTTP Basic Auth)
DOCS_PASSWORD_ENABLED=False
DOCS_USER=admin
DOCS_PASSWORD=changeme

# ======= Rate limiting variables ======= #
# Formato: {cantidad}/{unidad} — unidades: second, minute, hour, day
# Ejemplos: 10/second, 100/minute, 1000/hour
RATE_LIMIT_DEFAULT=100/minute
# Si True, los contadores se almacenan en Redis (compartido entre workers).
# Si False, se almacenan en memoria del proceso (default, sin dependencias externas).
RATE_LIMIT_REDIS_ENABLED=False
RATE_LIMIT_REDIS_URL=redis://localhost:6379

# ======= Pagination variables ======= #
# Máximo de elementos permitidos por página. Hard cap en código: 200.
# Si este valor supera 200, se ignora y se usa 200.
PAGINATION_MAX_SIZE=50

# ======= Request size variables ======= #
# Tamaño máximo permitido del cuerpo de la solicitud en megabytes.
# Aplica a POST, PUT y PATCH. Rutas excluidas se configuran en código.
REQUEST_MAX_SIZE_MB=10

# ======= CORS variables ======= #
# Origenes permitidos separados por coma. Usa * para permitir todos.
# IMPORTANTE: "*" es incompatible con allow_credentials=True en browsers.
# En produccion define origenes especificos: https://myapp.com,https://admin.myapp.com
CORS_ORIGINS=*


# ======= Database variables ======= #
DB_HOST=localhost
DB_USER=username
DB_PASS=password
DB_NAME=database
DB_PORT=3306
DB_ENGINE=sqlite # or mysql+pymysql or postgresql+psycopg2


# ======= Jasmin Telnet (jcli) variables ======= #
# Host where Jasmin's Telnet CLI is listening (always localhost in sidecar mode)
JASMIN_TELNET_HOST=localhost
JASMIN_TELNET_PORT=8990
JASMIN_TELNET_USER=jcliadmin
JASMIN_TELNET_PASSWORD=jclipwd
# Seconds to wait for a jcli response before timing out
JASMIN_TELNET_TIMEOUT=10

# ======= Jasmin HTTP API variables ======= #
# Host where Jasmin's HTTP send API is listening (always localhost in sidecar mode)
JASMIN_HTTP_HOST=localhost
JASMIN_HTTP_PORT=1401

# ======= Admin API variables ======= #
# API Key requerida en el header X-API-Key para todos los endpoints excepto /health
# En producción (APP_ENV=production) el servidor NO arranca si esta variable está vacía
# Genera con: python -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_API_KEY=
# Directorio donde se almacenan los scripts Python de interceptores
JASMIN_SCRIPTS_DIR=/etc/jasmin/scripts
